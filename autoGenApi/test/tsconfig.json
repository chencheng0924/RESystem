{
    "compilerOptions": {
      "module": "es2020", 
      "target": "es2020",
      "types": ["jest", "node"],
      "baseUrl": ".",
      "paths": {
        "@/*": ["../../src/*"] // 依據擺放位置調整
      },
      "esModuleInterop": true,
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "isolatedModules": true,
      "skipLibCheck": true,
      "strict": true
    }
}
  